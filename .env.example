# Server
NODE_ENV=development
PORT=4000
API_PREFIX=api

# Database
# Option A: SQLite (no setup – use for local dev)
DB_TYPE=sqlite
DB_SQLITE_PATH=data/trilink.sqlite

# Option B: PostgreSQL (uncomment and set DB_TYPE=postgres; create user first)
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=trilink
# DB_PASSWORD=trilink_secret
# DB_DATABASE=trilink

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Seed admin (used only when running seed script)
SEED_ADMIN_EMAIL=admin@trilink.edu
SEED_ADMIN_PASSWORD=Admin@123

# Optional: future integrations (see GET /api/integrations/status)
# MONGO_URI=
# VECTOR_SERVICE_URL=
# AI_SERVICE_URL=

# CORS: comma-separated allowed origins; omit for permissive dev (reflect)
# CORS_ORIGIN=https://app.example.com,https://admin.example.com

# Rate limit (authenticated API); health is excluded
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=150

# Weekly parent digest (Monday 08:00 UTC) — set to false to disable cron
# WEEKLY_DIGEST_ENABLED=true
