# Copy to .env and adjust. Used by Nest and by Docker Compose (see docker-compose.yml).
#
# Server
NODE_ENV=development
PORT=4000
API_PREFIX=api

# Database — PostgreSQL (default). With Docker Compose api/seed: DB_HOST is overridden to `db`
# unless you set DATABASE_URL (Neon / external DB — then the URL wins and local `db` is unused).
#
# --- Neon (or any hosted Postgres): paste the connection string from the Neon dashboard ---
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# (Do not set DB_HOST when using DATABASE_URL, or keep Docker from overriding — see README.)
#
# --- Local Docker Postgres (host machine): ---
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=trilink
DB_PASSWORD=trilink_secret
DB_DATABASE=trilink
#
# --- Discrete credentials to a TLS host (e.g. Neon host without URL): set DB_SSL=true ---
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Optional: SQLite file DB (e.g. local dev without Docker Postgres)
# DB_TYPE=sqlite
# DB_SQLITE_PATH=data/trilink.sqlite
# Copy SQLite → Neon: install pgloader (`sudo apt install pgloader`), set DATABASE_URL, then:
#   ./scripts/push-sqlite-to-neon.sh

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Seed admin (used only when running seed script)
SEED_ADMIN_EMAIL=admin@trilink.edu
SEED_ADMIN_PASSWORD=Admin@123
# Empty Neon DB + NODE_ENV=production: run seed once with SEED_SYNC_SCHEMA=true, then unset (creates tables + admin)
# SEED_SYNC_SCHEMA=true

# Optional: future integrations (see GET /api/integrations/status)
# MONGO_URI=
# VECTOR_SERVICE_URL=
# AI_SERVICE_URL=http://localhost:8000
# INTERNAL_API_KEY=change-this-shared-secret

# CORS: comma-separated allowed origins; omit for permissive dev (reflect)
# CORS_ORIGIN=https://app.example.com,https://admin.example.com

# Rate limit (authenticated API); health is excluded
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=150

# Weekly parent digest (Monday 08:00 UTC) — set to false to disable cron
# WEEKLY_DIGEST_ENABLED=true

# Email Configuration (for user registration notifications)
# SMTP server settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=TriLink School
SMTP_FROM_EMAIL=noreply@trilink.edu

# Login URL for email templates (where users will be directed to log in)
LOGIN_URL=http://localhost:3000/login

# Registration welcome email (required for production: when SMTP_HOST is set, send failures roll back registration)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=TriLink <noreply@yourdomain.com>
# Sign-in links in registration emails (role-specific; each falls back to APP_LOGIN_URL if unset)
# APP_LOGIN_URL=https://app.yourdomain.com/login
# APP_LOGIN_URL_STUDENT=https://app.yourdomain.com/student/login
# APP_LOGIN_URL_TEACHER=https://app.yourdomain.com/teacher/login
# APP_LOGIN_URL_PARENT=https://app.yourdomain.com/parent/login

# Cloudinary — textbook and resource file CDN (free tier: 25GB storage)
# Create account at https://cloudinary.com and copy credentials from Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RESOURCE_STORAGE_DRIVER=cloudinary
RESOURCE_STORAGE_CLOUDINARY_FOLDER=trilink_uploads
